// ============================================================
// DevJobs.br — Prisma Schema
// Database: MySQL | ORM: Prisma
// Security: Passwords hashed (bcrypt), email unique constraint,
//           role-based access, soft-delete ready
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  CANDIDATE
  COMPANY
  ADMIN
}

enum JobType {
  REMOTE
  HYBRID
  ONSITE
}

enum JobLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

// ─── User ────────────────────────────────────────────────────
// Supports candidates, companies, and admins.
// Password is hashed with bcrypt before storage (handled in app layer).
// `emailVerified` ensures email confirmation for security.

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String? // Hashed with bcrypt — null for OAuth-only users
  image         String?   @db.Text
  role          Role      @default(CANDIDATE)

  // ── Candidate-specific fields ──
  title        String?
  bio          String?   @db.Text
  skills       String?   @db.Text
  resume       String?   @db.Text // Base64 ou URL do PDF
  linkedin     String?
  github       String?
  portfolio    String?
  phone        String?
  isPro        Boolean   @default(false) @map("is_pro")
  proExpiresAt DateTime? @map("pro_expires_at")

  // ── Company-specific fields ──
  companyName    String? @map("company_name")
  companyLogo    String? @map("company_logo") @db.Text
  companySite    String? @map("company_site")
  companySize    String? @map("company_size")
  companyAbout   String? @map("company_about") @db.Text
  premiumCredits Int     @default(0) @map("premium_credits")

  // ── Stripe ──
  stripeCustomerId     String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")

  // ── Security & Audit ──
  lastLoginAt DateTime? @map("last_login_at")
  loginCount  Int       @default(0) @map("login_count")
  isActive    Boolean   @default(true) @map("is_active")
  isBanned    Boolean   @default(false) @map("is_banned")

  // ── Relations ──
  jobs         Job[]
  applications Application[]
  accounts     Account[]
  sessions     Session[]

  // ── Timestamps ──
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@index([isPro])
  @@map("users")
}

// ─── Job ─────────────────────────────────────────────────────
// Posted by companies. Premium jobs get highlighted placement.

model Job {
  id          String @id @default(cuid())
  title       String
  slug        String @unique
  description String @db.Text

  // ── Company Info (denormalized for performance) ──
  company     String
  companyLogo String? @map("company_logo") @db.Text

  // ── Job Details ──
  location  String
  type      JobType  @default(REMOTE)
  level     JobLevel @default(MID)
  salaryMin Int?     @map("salary_min")
  salaryMax Int?     @map("salary_max")
  currency  String   @default("BRL")

  // ── Tags & Benefits ──
  tags     String  @db.Text // JSON array stored as text: ["React", "Node.js"]
  benefits String? @db.Text // JSON array: ["VR", "Home Office"]

  // ── Status & Visibility ──
  status    JobStatus @default(DRAFT)
  isPremium Boolean   @default(false) @map("is_premium")

  // ── Premium Payment ──
  stripePaymentId  String?   @map("stripe_payment_id")
  premiumExpiresAt DateTime? @map("premium_expires_at")

  // ── Metrics ──
  viewCount  Int @default(0) @map("view_count")
  clickCount Int @default(0) @map("click_count")

  // ── Relations ──
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId     String        @map("author_id")
  applications Application[]

  // ── Timestamps ──
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  @@index([slug])
  @@index([status])
  @@index([type])
  @@index([level])
  @@index([isPremium])
  @@index([authorId])
  @@index([createdAt])
  @@map("jobs")
}

// ─── Application ─────────────────────────────────────────────
// Tracks candidate applications to jobs.
// PRO candidates appear at the top of the list for recruiters.

model Application {
  id String @id @default(cuid())

  coverLetter String?           @map("cover_letter") @db.Text
  status      ApplicationStatus @default(PENDING)

  // ── Notes (recruiter-side) ──
  recruiterNotes String? @map("recruiter_notes") @db.Text

  // ── Relations ──
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId  String @map("job_id")

  // ── Timestamps ──
  appliedAt  DateTime  @default(now()) @map("applied_at")
  reviewedAt DateTime? @map("reviewed_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([userId, jobId]) // Prevent duplicate applications
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@map("applications")
}

// ─── NextAuth: Account ───────────────────────────────────────
// OAuth provider accounts (Google, GitHub, etc.)

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ─── NextAuth: Session ───────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── NextAuth: Verification Token ────────────────────────────
// Used for email verification and password reset tokens.

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
